{
    "level": "info",
    "topics": [
        "environment"
    ],
    "expanded": false,
    "title_element": {
"name": "[% edq(lang('forest_footprint_2026')) %]",
      "title": "[% edq(lang('forest_footprint_2026')) %] - [% product.forest_footprint_2026.grade.ucfirst %]",
      "subtitle": "[% edq(lang('forest_footprint_2026_under_development')) %]",
        "icon_url": "[% static_subdomain %]/images/attributes/dist/forest-footprint-[% product.forest_footprint_2026.grade %].svg",
        "type": "grade",
        "grade": "[% product.forest_footprint_2026.grade %]"
    },
    "elements": [
        {
            "element_type": "text",
            "text_element": {
                "type": "summary",
                "html": `
                <p><strong>[% lang('forest_footprint_2026') %]</strong></p>
                <p>[% lang('forest_footprint_2026_under_development') %]</p>
                <p><strong>[% lang('forest_footprint_2026_overall_grade') %][% sep %]:</strong> [% product.forest_footprint_2026.grade.ucfirst %]</p>
                <p><strong>[% lang('total_forest_footprint') %][% sep %]:</strong> [% product.forest_footprint_2026.total_footprint_per_kg FILTER format("%.2f"); %] [% lang('square_meters_per_kg_of_food') %]</p>
                `
            }
        },
        [% FOREACH primary_id IN ['en:cocoa', 'en:coffee', 'en:palm-oil'] %]
        [% IF product.forest_footprint_2026.primary_ingredients.${primary_id}.ingredients.defined && product.forest_footprint_2026.primary_ingredients.${primary_id}.ingredients.size %]
        [% SET primary = product.forest_footprint_2026.primary_ingredients.${primary_id} %]
        {
            "element_type": "text",
            "text_element": {
                "type": "summary",
                "html": `
                <h3>[% display_taxonomy_tag("ingredients", primary_id).ucfirst %]</h3>
                <p><strong>[% lang('forest_footprint_2026_primary_ingredient_grade') %][% sep %]:</strong> [% primary.grade.ucfirst %]</p>
                <p><strong>[% lang('forest_footprint_2026_primary_ingredient') %][% sep %]:</strong> [% primary.footprint_per_kg FILTER format("%.2f"); %] [% lang('square_meters_per_kg_of_food') %]</p>
                `
            }
        },
        {
            "element_type": "table",
            "table_element": {
                "id": "forest_footprint_2026_[% primary_id %]_table",
                "title": "[% display_taxonomy_tag("ingredients", primary_id) %]",
                "columns": [
                    {
                        "text": "[% edq(lang('ingredients_s')) | ucfirst %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('percent_in_product')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('forest_footprint_2026_primary_ingredient')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('processing_factor')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('origin')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('forest_footprint_2026_origin_footprint')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('forest_footprint_2026_label')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('deforestation_risk')) %]",
                        "type": "text"
                    },
                    {
                        "text": "[% edq(lang('forest_footprint')) %]<br><span style=\"font-weight:normal\">([% edq(lang('square_meters_per_kg_of_food')) %])</span>",
                        "type": "text"
                    },
                ],
                "rows": [
                    [% FOREACH ingredient IN primary.ingredients %]
                    {
                        "values": [
                            {
                                "text": "[% display_taxonomy_tag("ingredients", ingredient.ingredient_id) %]"
                            },
                            {
                                "text": "[% ingredient.percent FILTER format("%.2f"); %] %"
                            },
                            {
                                "text": "[% display_taxonomy_tag("ingredients", ingredient.primary_ingredient_id) %]"
                            },
                            {
                                "text": "[% ingredient.transformation_factor FILTER format("%.2f"); %]"
                            },
                            {
                                "text": "[% display_taxonomy_tag("origins", ingredient.origin_id) %]"
                            },
                            {
                                "text": "[% ingredient.origin_footprint FILTER format("%.3f"); %]"
                            },
                            {
                                "text": "[% IF ingredient.label_id.defined %][% display_taxonomy_tag("labels", ingredient.label_id) %][% ELSE %]-[% END %]"
                            },
                            {
                                "text": "[% ingredient.risk_factor * 100 FILTER format("%.0f"); %] %"
                            },
                            {
                                "text": "[% ingredient.footprint_per_kg FILTER format("%.2f"); %]"
                            },
                        ]
                    }[% UNLESS loop.last %],[% END %]
                    [% END %]
                ]
            }
        }[% UNLESS loop.last %],[% END %]
        [% END %]
        [% END %]
    ]
}
