msgid "Thank you for joining us!"
msgstr "Bizə qoşulduğunuz üçün təşəkkür edirik!"

msgctxt "add_user_you_can_edit"
msgid "You can now add and edit products on the web or with our free <a href=\"%s\">mobile app</a>."
msgstr "Artıq vebdə və ya pulsuz <a href=\"%s\">mobil tətbiqimiz</a> ilə məhsullar əlavə edə və redaktə edə bilərsiniz."

msgctxt "join_us_on_slack"
msgid "Join us on Slack"
msgstr "Slack-da bizə qoşulun"

msgctxt "add_user_join_the_project"
msgid "%s is a collaborative project to which you can bring much more than new products: your energy, enthusiasm and ideas!"
msgstr "%s yeni məhsullardan daha çoxunu: enerjinizi, həvəsinizi və ideyalarınızı gətirə biləcəyiniz əməkdaşlıq layihəsidir!"

msgctxt "add_user_join_us_on_slack"
msgid "We use a discussion system called Slack where all project participants can exchange and collaborate. Please join! We would be happy to know you!"
msgstr "Biz bütün layihə iştirakçılarının mübadilə edə və əməkdaşlıq edə biləcəyi Slack adlı müzakirə sistemindən istifadə edirik. Zəhmət olmasa, qoşulun! Sizi tanımaqdan məmnun olarıq!"

msgctxt "add_user_you_can_edit_pro"
msgid "You can now easily import your product data and photos."
msgstr "Artıq məhsul məlumatlarınızı və şəkillərinizi asanlıqla idxal edə bilərsiniz."

msgctxt "add_user_you_can_edit_pro_promo"
msgid "You can now add and edit your products and import their data and photos on our free <a href=\"%s\">platform for producers</a>."
msgstr "Artıq istehsalçılar üçün pulsuz <a href=\"%s\">platformamızda</a> məhsullarınızı əlavə edə, redaktə edə və onların məlumatlarını və şəkillərini idxal edə bilərsiniz."

msgctxt "add_user_existing_org"
msgid "There is already an existing organization with the name %s."
msgstr "Artıq %s adlı mövcud bir təşkilat mövcuddur."

msgctxt "add_user_existing_org_pending"
msgid "Your request to join the organization is pending approval of the organization administrator."
msgstr "Təşkilata qoşulmaq üçün müraciətiniz təşkilat administratorunun təsdiqini gözləyir."

msgctxt "add_user_requested_org_processing"
msgid "Your organization request has been received and is being processed."
msgstr "Təşkilat sorğunuz qəbul edildi və emal olunur."

