# openbeautyfacts.org configuration

# we must set the nginx container type before productopener-mappings.include
# abuse map gently because "set" is not allowed outside a server block
map "" $nginx_container {
	default "proxmox_ct";
}

# some variables definitions to handle flavors and other topics
include snippets/productopener-mappings.include;

# variables useful to snippets/expiry-headers.include
# are loaded from /etc/nginx/conf.d/expires-no-json-xml.conf

server {

	listen 80;
	listen [::]:80;

	# Product Opener needs a root domain + a wildcard for all subdomains
	server_name openbeautyfacts.org *.openbeautyfacts.org;

	# product opener common directives
	include snippets/productopener-server.include;
	include snippets/productopener-uploads-defaults.include;

}
